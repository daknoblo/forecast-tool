# Copy this file to ".env" (same directory as docker-compose.yml) and fill in
# your secret. The .env file is git-ignored. Docker Compose loads it
# automatically and passes the value to the container.

# Secret API key for the AI endpoint (Azure OpenAI-compatible). The key is NOT
# stored in data.json; it is only read from this environment variable.
FORECAST_AI_API_KEY=

# Bearer tokens for the JSON API under /api/v1 (see docs/API.md). The read token
# grants read-only (GET) access; the write token grants read+write. Leave both
# empty to disable the API entirely. Use long, random values.
FORECAST_API_READ_TOKEN=
FORECAST_API_WRITE_TOKEN=
